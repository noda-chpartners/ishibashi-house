---
import { getImage } from 'astro:assets';

import pcHero from '../../assets/images/pc-hero.png';
import tabHero from '../../assets/images/tab-hero.png';
import spHero from '../../assets/images/sp-hero.png';

const pc = await getImage({ src: pcHero, format: 'webp' });
const tab = await getImage({ src: tabHero, format: 'webp' });
const sp = await getImage({ src: spHero, format: 'webp' });
---
<section class="hero">
  <picture class="hero-picture">
    <source media="(max-width: 520px)" srcset={sp.src} />
    <source media="(max-width: 890px)" srcset={tab.src} />
    <img
      src={pc.src}
      alt="初代組系ラーメン麵魂力組"
      data-hero-image
    />
  </picture>

  <div class="hero-content">
    <p class="hero-copy">
      <span class="hero-copy-line">うまい、</span>
      <span class="hero-copy-line">安い、</span>
      <span class="hero-copy-line">楽しい！</span>
    </p>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;

    &::after {
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(
        160deg,
        rgba(0, 0, 0, 0.15) 0%,
        rgba(0, 0, 0, 0.35) 55%,
        rgba(0, 0, 0, 0.55) 100%
      );
      content: "";
      pointer-events: none;
    }
  }

  .hero-content {
    position: absolute;
    bottom: clamp(20px, 4vh, 48px);
    left: clamp(16px, 3vw, 48px);
    z-index: 3;
    transform: rotate(-10deg);
    transform-origin: left bottom;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(4px, 0.8vw, 10px);
    margin: 0;
  }

  .hero-copy-line {
    display: inline-block;
    padding: 0.05em 0.35em;
    border-radius: 4px;
    background-color: rgba(235, 65, 65, 0.88);
    color: yellow;
    font-size: clamp(1.8rem, 5.5vw, 3.6rem);
    font-weight: bold;
    line-height: 1.25;
    letter-spacing: 0.05em;
    white-space: nowrap;

    &:nth-child(2) {
      margin-left: clamp(20px, 4vw, 48px);
      background-color: rgba(255, 221, 0, 0.92);
      color: rgba(235, 65, 65, 1);
      text-shadow: none;
    }

    &:nth-child(3) {
      margin-left: clamp(40px, 8vw, 96px);
    }
  }

  @include tb {
    .hero-content {
      bottom: clamp(16px, 3vh, 32px);
      left: clamp(12px, 4vw, 32px);
      transform: rotate(-8deg);
    }
  }

  @include sp {
    .hero-copy-line {
      font-size: clamp(1.5rem, 8vw, 2.2rem);
    }
  }
</style>

---
import { getImage } from 'astro:assets';

import pcHero from '../../assets/images/pc-hero.png';
import tabHero from '../../assets/images/tab-hero.png';
import spHero from '../../assets/images/sp-hero.png';

const pc = await getImage({ src: pcHero, format: 'webp' });
const tab = await getImage({ src: tabHero, format: 'webp' });
const sp = await getImage({ src: spHero, format: 'webp' });
---
<section class="hero">
  <picture class="hero-picture">
    <source media="(max-width: 520px)" srcset={sp.src} />
    <source media="(max-width: 890px)" srcset={tab.src} />
    <img
      src={pc.src}
      alt="居酒屋食堂いしばしさん家"
      data-hero-image
    />
  </picture>

  <div class="hero-content">
    <div class="hero-sign">
      <p class="hero-copy">
        <span class="hero-copy-line">肉業界36年の実績あり</span>
        <span class="hero-copy-line">お肉を美味しく食べて頂きます</span>
      </p>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;

    &::after {
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(
        160deg,
        rgba(0, 0, 0, 0.15) 0%,
        rgba(0, 0, 0, 0.35) 55%,
        rgba(0, 0, 0, 0.55) 100%
      );
      content: "";
      pointer-events: none;
    }
  }

  .hero-content {
    position: absolute;
    top: 40%;
    left: 65%;
    z-index: 3;
    transform: translate(-50%, -50%);
  }


  .hero-sign {
    position: relative;
    padding-top: clamp(8px, 1.4vw, 16px);
  }

@media (min-width: 768px) {
  .hero-sign {
    padding-top: clamp(140px, 10vh, 120px);
  }
}


  .hero-copy {
    display: flex;
    flex-direction: row-reverse;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(10px, 1.5vw, 20px);
    margin: 0;
  }

  .hero-copy-line {
    display: inline-block;
    writing-mode: vertical-rl;
    text-orientation: upright;
    padding: 0.35em 0.1em;
    border-radius: 4px;
    color: white;
    font-size: clamp(1rem, 2.4vw, 1.6rem);
    text-shadow: 0 2px 4px rgb(175, 109, 9);
    font-weight: bold;
    line-height: 1.3;
    letter-spacing: 0.08em;
    white-space: nowrap;

    &:nth-child(2) {
      margin-top: clamp(12px, 2vw, 24px);
    }
  }

  @include tb {
    .hero-copy-line {
      font-size: clamp(0.9rem, 2.8vw, 1.4rem);
    }
  }

  @include sp {
    .hero-copy-line {
      font-size: clamp(0.8rem, 3.6vw, 1.2rem);
    }
  }
</style>

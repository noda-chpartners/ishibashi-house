---
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../../config/site';
---
<section class="section" id="contact">
  <div class="inner">
    <div class="section-title">
      <h2 class="title">お問い合わせ</h2>
    </div>
    <div class="content">
      <p class="lead">お問い合わせはお電話にて承っております。<br class="break" />お気軽にお問い合わせください。</p>
      <div class="cta-buttons">
        <a href="tel:0963690650" class="tel-button">
          <Icon name="mdi:phone" class="tel-icon" />
          <span class="tel-number">096-369-0650</span>
        </a>
        <a class="tabelog-button" href={ siteConfig.sns.tabelog } target="_blank" rel="noopener noreferrer">
          <Icon class="tabelog-icon" name="simple-icons:tabelog" />
          <span>食べログを見る</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 40px;
    margin-top: 80px;
  }

  .lead {
    font-size: clamp(0.8rem, 10vw, 1rem);
    line-height: 2;

    @include sp {
      font-size: 0.8rem;
    }
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
  }

  .tel-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 20px 56px;
    border: 1px solid rgba(255, 255, 255);
    border-radius: 999px;
    background-color: rgba(235, 65, 65, 0.85);
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: bold;
    color: yellow;
    letter-spacing: 0.05em;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s;

    @include sp {
      padding: 16px 36px;
    }
  }

  .tel-icon {
    font-size: 1.5rem;
  }

  .tabelog-button {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 20px 56px;
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: 999px;
  background-color: #ff9600; /* 食べログ系オレンジ */
  font-size: clamp(1rem, 4vw, 1.5rem);
  font-weight: bold;
  color: #fff;
  letter-spacing: 0.05em;
  white-space: nowrap;
  transition: background-color 0.2s, opacity 0.2s;
  @include sp {
    padding: 16px 36px;
  }
  &:hover {
    opacity: 0.9;
  }
}
.tabelog-icon {
  font-size: 1.5rem;
}

</style>
---
import { Icon } from 'astro-icon/components';

import { siteConfig } from '../../config/site';

const { sns } = siteConfig;
---
<section class="section" id="info">
  <div class="inner info">
    <div class="section-title">
      <h2 class="title">店舗情報</h2>
    </div>
    <div class="content">
      <div class="info-body">
        <dl class="info-table">
          <div class="info-row">
            <dt class="info-label">店舗名</dt>
            <dd class="info-data">居酒屋食堂 いしばしさん家</dd>
          </div>
          <div class="info-row">
            <dt class="info-label">電話番号</dt>
            <dd class="info-data">
              <a href="tel:0963690650" class="tel">096-369-0650</a>
            </dd>
          </div>
          <div class="info-row">
            <dt class="info-label">住所</dt>
            <dd class="info-data">
              <address class="address">熊本市東区東本町1-98</address>
            </dd>
          </div>
          <div class="info-row">
            <dt class="info-label">アクセス</dt>
            <dd class="info-data">
              健軍電停終点から徒歩約270歩約3分<br />
              自衛隊通り右側
            </dd>
          </div>
          <div class="info-row">
            <dt class="info-label">営業時間</dt>
            <dd class="info-data">
              ●Theシンプルカレー<br />
              【月〜土（昼）】<br />11:30~14:00(14:00オーダーストップ)<br />
              ●居酒屋食堂 いしばしさん家<br />
              【月•火•水•金•土（夜）】<br />18:00~23:00(22:40オーダーストップ)<br />
              【日祝（昼飲み）】<br />12:00〜20:00（19:30オーダーストップ）
            </dd>
          </div>
          <div class="info-row">
            <dt class="info-label">定休日</dt>
            <dd class="info-data">
  <div>
    ●Theシンプルカレー<br/>不定休<br/>
    ●居酒屋食堂いしばしさん家<br/>
    毎週木曜日と月2回火曜日<br/>
    <span class="info-note">※インスタにてご確認お願いします。</span>
  </div>
</dd>
          </div>
          <div class="info-row">
            <dt class="info-label">席数</dt>
            <dd class="info-data">１階<br />カウンター7席<br />２人 テーブル席1卓<br />２階<br />4人テーブル席5卓<br />最大24名様</dd>
          </div>
          <div class="info-row sns">
            <dt class="info-label">SNS</dt>
            <dd class="info-data">
              <a href={ sns.instagram } class="sns-link" target="_blank" rel="noopener noreferrer"><Icon name="simple-icons:instagram" /></a>
              <a href={ sns.tabelog } class="sns-link" target="_blank" rel="noopener noreferrer"><Icon name="simple-icons:tabelog" /></a>
            </dd>
          </div>
        </dl>
      </div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .inner.info {
    @include sp {
      padding: 0;
    }
  }

  .content {
    position: relative; 
    max-width: 900px;
    width: 100%;
    height: auto;
    background-image: url('../../assets/images/outside.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border-radius: 5px;
    overflow: hidden;
    margin: 80px auto;
    padding: 40px;
    color: #fff;
    z-index: 1;

    &::after {
      position: absolute;
      inset: 0;
      z-index: -1;
      border-radius: inherit;
      background: rgba(0, 0, 0, 0.8);
      content: "";
      pointer-events: none;
    }

    @include sp {
      padding: 10px;
    }
  }

  .info-body {
    display: flex;
    gap: clamp(24px, 5vw, 80px);
    align-items: flex-start;
  }

  .info-table {
    flex: 1 1 0;
    min-width: 0;
  }

  .info-row {
    display: flex;
    gap: 24px;
    padding: 24px 0;
  }

  .info-row.sns {
    align-items: baseline;
  }

  .sns-link {
    display: inline-flex;
  }

  .info-label {
    flex: 0 0 6em;
  }

  .info-data {
    display: flex;
    flex: 1 1 0;
    min-width: 0;
    gap: 20px;
    @include sp {
      font-size: clamp(0.7rem, 5vw, 0.9rem);
    }
  }

.info-note {
  display: block;
  flex-basis: 100%;
  font-size: 0.85em;
  margin-top: 0.25em;
}

  .tel {
    text-decoration: underline;
  }

  .info-image {
    flex: 1 1 0;
    min-width: 0;
    max-width: 480px;
  }

  @include tb {
    .info-body {
      flex-direction: column;
      align-items: center;
    }

    .info-image {
      max-width: 400px;   /* 100% → 控えめな固定値に */
      width: 100%;        /* 画面が400px以下のときは画面に追従 */
      order: -1;
    }
  }

  @include sp {
    .info-row {
      flex-direction: column;
      gap: 8px;
      padding: 16px 0;
    }

    .info-label {
      flex: none;
      font-size: 0.85rem;
    }
  }
</style>
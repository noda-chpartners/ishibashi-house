---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../../config/site';

import Logo from '../../assets/images/logo.png';

const navLinks = [
  { href: '#about', label: '当店について' },
  { href: '#menu', label: '人気メニュー' },
  { href: '#info', label: '店舗情報' },
  { href: '#info', label: 'アクセス' },
  { href: '#contact', label: 'お問い合わせ' },
];

const { sns } = siteConfig;
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <Image src={Logo} alt="" />
      </a>
    </div>

    <nav class="footer-nav" aria-label="フッターナビゲーション">
      <ul class="footer-nav-list">
        {navLinks.map((link) => (
          <li><a href={link.href} class="footer-nav-link">{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <ul class="footer-sns">
      <li>
        <a href={ sns.instagram } class="footer-sns-link" target="_blank" rel="noopener noreferrer" aria-label="instagram">
          <Icon name="simple-icons:instagram" />
        </a>
      </li>
      <li>
        <a href={ sns.tabelog } class="footer-sns-link" target="_blank" rel="noopener noreferrer" aria-label="tabelog">
          <Icon name="simple-icons:tabelog" />
        </a>
      </li>
    </ul>

    <small class="copyright">&copy; 2026 居酒屋食堂 いしばしさん家</small>
  </div>
</footer>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .footer {
    background-color: rgba(235, 65, 65, 0.85);
    color: rgba(255, 255, 255, 0.9);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
    padding: 60px 40px 40px;

    @include sp {
      padding: 48px 20px 32px;
      gap: 28px;
    }
  }

  .footer-logo {
    display: block;
    max-width: 150px;
  }

  .footer-sns {
    display: flex;
    gap: 20px;
  }

  .footer-nav-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px 32px;

    @include sp {
      flex-direction: column;
      gap: 12px 24px;
    }
  }

  .copyright {
    display: flex;
    justify-content: center;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.05em;
  }
</style>
---
import { Image } from 'astro:assets';

import Logo from '../../assets/images/logo.png';

const navLinks = [
  { href: '#about', label: '当店について' },
  { href: '#menu', label: '人気メニュー' },
  { href: '#info', label: '店舗情報' },
  { href: '#access', label: 'アクセス' },
  { href: '#contact', label: 'お問い合わせ', isCta: true },
];
---
<header class="header" data-header>
  <div class="header-inner">
    <h1 class="logo">
      <a href="/" class="logo-link">
        <Image src={Logo} alt="居酒屋食堂 いしばしさん家" />
      </a>
    </h1>

    <button
      type="button"
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="header-nav"
      aria-label="メニュー"
    >
      <span class="nav-toggle-line" aria-hidden="true" />
      <span class="nav-toggle-line" aria-hidden="true" />
      <span class="nav-toggle-line" aria-hidden="true" />
    </button>

    <nav class="nav" id="header-nav" aria-label="メインナビゲーション">
      <ul class="nav-list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { 'nav-link--cta': link.isCta }]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 110;
    transition: background-color 0.3s ease, box-shadow 0.3s ease;

    &.is-scrolled {
      background-color: rgba(235, 65, 65, 0.85);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
    padding: 10px;

    @include tb {
      padding: 16px 20px;
    }
  }

  .logo {
    position: relative;
    z-index: 120;
    max-width: 100px;
    height: auto;

    @include tb {
      max-width: 120px;
    }
  }

  .nav-toggle {
    display: none;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: clamp(16px, 2vw, 32px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link {
    display: inline-block;
    color: yellow;
    font-size: clamp(0.8rem, 1.5vw, 0.9rem);
    font-weight: bold;
    letter-spacing: 0.05em;
    white-space: nowrap;
    transition: opacity 0.2s;

    &:hover {
      opacity: 0.8;
    }
  }

  .nav-link--cta {
  padding: 8px 20px;
  border: 1px solid yellow;
  border-radius: 999px;
  background-color: rgba(235, 65, 65, 0.95);
  &:hover {
    opacity: 1;
  }
}

  @include tb {
    .nav-toggle {
      position: relative;
      z-index: 120;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 6px;
      width: 44px;
      height: 44px;
      padding: 0;
      border: none;
      background: transparent;
      cursor: pointer;

      &.is-open {
        .nav-toggle-line:nth-child(1) {
          transform: translateY(8px) rotate(45deg);
        }

        .nav-toggle-line:nth-child(2) {
          opacity: 0;
        }

        .nav-toggle-line:nth-child(3) {
          transform: translateY(-8px) rotate(-45deg);
        }
      }
    }

    .nav-toggle-line {
      display: block;
      width: 24px;
      height: 2px;
      margin: 0 auto;
      background-color: yellow;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .nav {
      position: fixed;
      top: 0;
      right: 0;
      z-index: 115;
      width: min(280px, 85vw);
      height: 100dvh;
      padding: 96px 24px 40px;
      background-color: rgba(235, 65, 65, 0.95);
      transform: translateX(100%);
      transition: transform 0.3s ease;

      &.is-open {
        transform: translateX(0);
      }
    }

    .nav-list {
      flex-direction: column;
      align-items: center;
      gap: 28px;
    }

    .nav-link {
      font-size: 1rem;
    }
  }

  :global(body.is-nav-open) {
    overflow: hidden;
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.getElementById('header-nav');
  const navLinks = nav?.querySelectorAll<HTMLAnchorElement>('.nav-link');

  const SCROLL_THRESHOLD = 50;

  function updateScrollState() {
    header?.classList.toggle('is-scrolled', window.scrollY > SCROLL_THRESHOLD);
  }

  function setNavOpen(open: boolean) {
    toggle?.classList.toggle('is-open', open);
    nav?.classList.toggle('is-open', open);
    toggle?.setAttribute('aria-expanded', String(open));
    document.body.classList.toggle('is-nav-open', open);
  }

  function closeNav() {
    setNavOpen(false);
  }

  updateScrollState();
  window.addEventListener('scroll', updateScrollState, { passive: true });

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.classList.contains('is-open');
    setNavOpen(!isOpen);
  });

  navLinks?.forEach((link) => {
    link.addEventListener('click', closeNav);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeNav();
    }
  });
</script>
